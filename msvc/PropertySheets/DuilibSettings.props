<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <ImportGroup Label="PropertySheets" />
    <PropertyGroup Label="UserMacros" />

    <!-- 公共配置 -->
    <Import Project="CommonSettings.props" />

    <!-- Skia: 需要添加include路径-->
    <Import Project="SkiaSettings.props" />

    <!-- SDL: 需要添加include路径，功能开关宏定义: DUILIB_SDL=1 开启，DUILIB_SDL=0 关闭-->
    <Import Project="SDLSettings.props" />

    <!-- libCEF: 需要添加include路径和是否支持的宏定义：DUILIB_CEF=1 开启，DUILIB_CEF=0 关闭 -->
    <Import Project="CEFSettings.props" />
    
    <!-- WebView2: 需要添加是否支持的宏定义： DUILIB_WEBVIEW2=1 开启，DUILIB_WEBVIEW2=0 关闭 -->
    <Import Project="WebView2Settings.props" />
    
    <!-- libjpeg-turbo: 需要添加include路径，需要添加是否支持的宏定义： DUILIB_JPEG_TURBO=1 开启，DUILIB_JPEG_TURBO=0 关闭  -->
    <Import Project="JpegTurboSettings.props" />
    
    <!-- libpag: 需要添加include路径，需要添加是否支持的宏定义： DUILIB_LIB_PAG=1 开启，DUILIB_LIB_PAG=0 关闭  -->
    <Import Project="LibPagSettings.props" />
  
    <PropertyGroup Label="Globals">
        <!-- Include 目录  -->
        <DuilibIncludeDirectories>$(SolutionDir)\..;$(ProjectDir);$(SkiaIncludeDir);$(SDLIncludeDir);$(LibCefIncludeDir);$(JpegTurboIncludeDir);$(LibPagIncludeDir)</DuilibIncludeDirectories>
    </PropertyGroup>

    <ItemDefinitionGroup>
        <ClCompile>
            <AdditionalIncludeDirectories>$(DuilibIncludeDirectories);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
            <PreprocessorDefinitions>$(SkiaPreprocessorDefinitions);DUILIB_SDL=$(SDLEnabled);DUILIB_WEBVIEW2=$(WebView2Enabled);DUILIB_CEF=$(LibCefEnabled);DUILIB_JPEG_TURBO=$(JpegTurboEnabled);DUILIB_LIB_PAG=$(LibPagEnabled);%(PreprocessorDefinitions)</PreprocessorDefinitions>
        </ClCompile>
    </ItemDefinitionGroup>

    <!-- $(EnableDuilibDll)的值为1时，表示使用动态链接库，最终编译为DLL形式，该变量在CommonSettings.props文件中定义 -->
    <!-- duilib项目，当使用DLL时，设置工程类型为动态链接库(*.dll)，否则为静态库(*.lib) -->
    <PropertyGroup Condition="'$(EnableDuilibDll)' == '1'">
        <ConfigurationType>DynamicLibrary</ConfigurationType>
    </PropertyGroup>
    <PropertyGroup Condition="'$(EnableDuilibDll)' != '1'">
        <ConfigurationType>StaticLibrary</ConfigurationType>
    </PropertyGroup>

    <!-- duilib项目，当使用DLL时，定义符号导出的宏 -->
    <ItemDefinitionGroup Condition="'$(EnableDuilibDll)' == '1'">
        <ClCompile>
            <PreprocessorDefinitions>DUILIB_EXPORTS;%(PreprocessorDefinitions)</PreprocessorDefinitions>
        </ClCompile>
        <Link Condition="'$(Configuration)'=='Debug'">
            <ImportLibrary>$(SolutionDir)\..\lib\$(Platform)\$(ProjectName)_d.lib</ImportLibrary>
        </Link>
        <Link Condition="'$(Configuration)'=='Release'">
            <ImportLibrary>$(SolutionDir)\..\lib\$(Platform)\$(ProjectName).lib</ImportLibrary>
        </Link>
    </ItemDefinitionGroup>
    
    <!-- duilib项目，当使用DLL时，定义输出DLL的目录和DLL文件名 -->
    <PropertyGroup Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)|$(Platform)'=='Release|x64'">
        <OutDir>$(SolutionDir)\..\bin\</OutDir>
        <TargetName>$(ProjectName)</TargetName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)|$(Platform)'=='Debug|x64'">
        <OutDir>$(SolutionDir)\..\bin\</OutDir>
        <TargetName>$(ProjectName)_d</TargetName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)|$(Platform)'=='Release|Win32'">
        <OutDir>$(SolutionDir)\..\bin\</OutDir>
        <TargetName>$(ProjectName)32</TargetName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)|$(Platform)'=='Debug|Win32'">
        <OutDir>$(SolutionDir)\..\bin\</OutDir>
        <TargetName>$(ProjectName)32_d</TargetName>
    </PropertyGroup>

    <!-- libCEF: lib路径, lib列表，libcef.dll延迟加载属性 -->
    <ItemDefinitionGroup Condition="'$(EnableDuilibDll)' == '1' And '$(LibCefEnabled)' != '0'">
        <Link>
            <AdditionalLibraryDirectories>$(LibCefLibDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
            <AdditionalDependencies>$(LibCefLibs);%(AdditionalDependencies)</AdditionalDependencies>
            <DelayLoadDLLs>$(LibCefDllName)</DelayLoadDLLs>
        </Link>
    </ItemDefinitionGroup>

    <!-- WebView2: 添加DUILIB_WEBVIEW2宏定义, include路径, lib路径, lib列表 -->
    <ItemDefinitionGroup Condition="'$(EnableDuilibDll)' == '1' And '$(WebView2Enabled)' != '0'">
        <Link>
            <AdditionalLibraryDirectories>$(WebView2LibDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
            <AdditionalDependencies>$(WebView2Libs);%(AdditionalDependencies)</AdditionalDependencies>
        </Link>
    </ItemDefinitionGroup>

    <!-- duilib项目，当使用DLL时，添加公共依赖lib文件的路径和lib库列表 -->
    <PropertyGroup Condition="'$(EnableDuilibDll)' == '1'" Label="Globals">
        <!-- 库文件Include -->
        <DuilibBinLibIncludeDir>$(SkiaLibDir);$(SDLLibDir);$(JpegTurboLibDir);$(LibPagLibDir);$(SolutionDir)\..\lib\$(Platform)\</DuilibBinLibIncludeDir>

        <!-- 库文件列表 -->
        <DuilibBinLibList>$(SkiaLibs);$(SDLLibs);$(JpegTurboLibs);$(LibPagLibs);$(DuilibThirdLibs);$(DuilibSystemLibs);</DuilibBinLibList>
    </PropertyGroup>

    <!-- duilib项目，当使用DLL时，设置库文件Include路径、lib列表-->
    <ItemDefinitionGroup Condition="'$(EnableDuilibDll)' == '1'">
        <ClCompile>
            <AdditionalIncludeDirectories>$(DuilibBinIncludeDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
        </ClCompile>
        <Link>
            <AdditionalLibraryDirectories>$(DuilibBinLibIncludeDir);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
            <AdditionalDependencies>$(DuilibBinLibList);$(CoreLibraryDependencies);%(AdditionalDependencies)</AdditionalDependencies>
        </Link>
    </ItemDefinitionGroup>
    <ItemDefinitionGroup Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)'=='Debug'">
        <Link>
            <AdditionalOptions>/NODEFAULTLIB:"libcmt.lib" %(AdditionalOptions)</AdditionalOptions>
        </Link>
    </ItemDefinitionGroup>

    <!-- duilib项目，当使用DLL时，添加嵌入的Manifest配置文件 -->
    <Import Project="BinManifestSettings.props" Condition="'$(EnableDuilibDll)' == '1'"/>
    
</Project>