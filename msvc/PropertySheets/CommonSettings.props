<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <ImportGroup Label="PropertySheets" />
    <PropertyGroup Label="UserMacros" />

    <!-- duilib项目，所有工程的输出公共配置 -->
    <PropertyGroup>
        <OutDir>$(SolutionDir)\..\lib\$(Platform)\</OutDir>
        <IntDir>$(SolutionDir)\build_temp\$(PlatformName)\$(ProjectName)\$(Configuration)\</IntDir>
    </PropertyGroup>    
    <PropertyGroup Condition="'$(Configuration)'=='Debug'">
        <TargetName>$(ProjectName)_d</TargetName>
    </PropertyGroup>
    <PropertyGroup Condition="'$(Configuration)'=='Release'">
        <TargetName>$(ProjectName)</TargetName>
    </PropertyGroup>
    
    <!-- duilib项目，支持VS2026(v145)和VS2022(v143)[主分支]，支持VS2019(v142)和VS2017(v141)[develop-cpp17分支] -->
    <PropertyGroup Condition="'$(VisualStudioVersion)' == '18.0'" Label="Configuration">
        <PlatformToolset>v145</PlatformToolset>
    </PropertyGroup>
    <PropertyGroup Condition="'$(VisualStudioVersion)' == '17.0'" Label="Configuration">
        <PlatformToolset>v143</PlatformToolset>
    </PropertyGroup>
    <PropertyGroup Condition="'$(VisualStudioVersion)' == '16.0'" Label="Configuration">
        <PlatformToolset>v142</PlatformToolset>
    </PropertyGroup>
    <PropertyGroup Condition="'$(VisualStudioVersion)' == '15.0'" Label="Configuration">
        <PlatformToolset>v141</PlatformToolset>
    </PropertyGroup>

    <!-- duilib项目，所有工程的SDK版本选项配置: VS2017需要设置具体的版本号，其他高版本只需要设置主版本号即可 -->
    <PropertyGroup Condition="'$(VisualStudioVersion)' != '15.0'" Label="Globals">
        <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    </PropertyGroup>
    <PropertyGroup Condition="'$(VisualStudioVersion)' == '15.0'" Label="Globals">
        <WindowsTargetPlatformVersion>$([Microsoft.Build.Utilities.ToolLocationHelper]::GetLatestSDKTargetPlatformVersion('Windows', '10.0'))</WindowsTargetPlatformVersion>
    </PropertyGroup>

    <!-- duilib项目，所有工程的编译选项配置: MT/MTd 或者 MD/MDd (根据当前文件所在目录是否存在duilib_dll.flag这个文件决定)-->
    <PropertyGroup Label="Globals">
        <DuilibDllFlagFile>$(MSBuildThisFileDirectory)\duilib_dll.flag</DuilibDllFlagFile>
        <EnableDuilibDll Condition="!Exists('$(DuilibDllFlagFile)')">0</EnableDuilibDll>
        <EnableDuilibDll Condition="Exists('$(DuilibDllFlagFile)')">1</EnableDuilibDll>
    </PropertyGroup>    
    <ItemDefinitionGroup>
        <ClCompile>
            <RuntimeLibrary Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)'=='Release'">MultiThreadedDll</RuntimeLibrary>
            <RuntimeLibrary Condition="'$(EnableDuilibDll)' != '1' And '$(Configuration)'=='Release'">MultiThreaded</RuntimeLibrary>
            <RuntimeLibrary Condition="'$(EnableDuilibDll)' == '1' And '$(Configuration)'=='Debug'">MultiThreadedDebugDll</RuntimeLibrary>
            <RuntimeLibrary Condition="'$(EnableDuilibDll)' != '1' And '$(Configuration)'=='Debug'">MultiThreadedDebug</RuntimeLibrary>
        </ClCompile>
    </ItemDefinitionGroup>

    <!-- duilib项目，支持VS2026和VS2022[主分支]：使用C++20标准 -->
    <ItemDefinitionGroup Condition="'$(VisualStudioVersion)' != '15.0' And '$(VisualStudioVersion)' != '16.0'">
        <ClCompile>
            <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
            <LanguageStandard>stdcpp20</LanguageStandard>
            <LanguageStandard_C>stdc17</LanguageStandard_C>
        </ClCompile>
    </ItemDefinitionGroup>

    <!-- duilib项目，支持VS2019和VS2017[develop-cpp17]：使用C++17标准 -->
    <ItemDefinitionGroup Condition="'$(VisualStudioVersion)' == '15.0' Or '$(VisualStudioVersion)' == '16.0'">
        <ClCompile>
            <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
            <LanguageStandard>stdcpp17</LanguageStandard>
            <LanguageStandard_C>stdc11</LanguageStandard_C>
        </ClCompile>
    </ItemDefinitionGroup>
    
    <!-- duilib项目，当使用DLL时，禁用STL的一个编译警告，并添加DLL相关的宏定义 -->
    <ItemDefinitionGroup Condition="'$(EnableDuilibDll)' == '1'">
        <ClCompile>
            <DisableSpecificWarnings>%(DisableSpecificWarnings);4251</DisableSpecificWarnings>
            <PreprocessorDefinitions>DUILIB_DLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
        </ClCompile>
        <ResourceCompile>
            <PreprocessorDefinitions>DUILIB_DLL;%(PreprocessorDefinitions)</PreprocessorDefinitions>
        </ResourceCompile>
    </ItemDefinitionGroup>

    <!-- duilib项目，自身的基础Lib名称列表，不含CEF、WebView2 -->
    <PropertyGroup Label="Globals">
        <DuilibSystemLibs>opengl32.lib;Imm32.lib;comctl32.lib;shlwapi.lib;</DuilibSystemLibs>
        <DuilibThirdLibs Condition="'$(Configuration)'=='Debug'">zlib_d.lib;cximage_d.lib;libpng_d.lib;libwebp_d.lib</DuilibThirdLibs>
        <DuilibThirdLibs Condition="'$(Configuration)'=='Release'">zlib.lib;cximage.lib;libpng.lib;libwebp.lib</DuilibThirdLibs>
        <DuilibMainLib Condition="'$(Configuration)'=='Debug'">duilib_d.lib</DuilibMainLib>
        <DuilibMainLib Condition="'$(Configuration)'=='Release'">duilib.lib</DuilibMainLib>
    </PropertyGroup>
</Project>